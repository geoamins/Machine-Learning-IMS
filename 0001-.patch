+{
+ "cells": [
+  {
+   "cell_type": "code",
+   "execution_count": null,
+   "id": "9675b8d1",
+   "metadata": {},
+   "outputs": [],
+   "source": [
+    "# Logistic Regression with 2 Features (from scratch) + Decision Boundary\n",
+    "import numpy as np\n",
+    "import matplotlib.pyplot as plt\n",
+    "\n",
+    "# -----------------------------\n",
+    "# Dataset (2 Features)\n",
+    "# -----------------------------\n",
+    "# Example: [Study Hours, Sleep Hours]\n",
+    "X = np.array([\n",
+    "    [1, 2],\n",
+    "    [2, 1],\n",
+    "    [3, 3],\n",
+    "    [4, 5],\n",
+    "    [5, 4]\n",
+    "])\n",
+    "\n",
+    "y = np.array([0, 0, 0, 1, 1]).reshape(-1, 1)"
+   ]
+  },
+  {
+   "cell_type": "code",
+   "execution_count": null,
+   "id": "d9df748a",
+   "metadata": {},
+   "outputs": [],
+   "source": [
+    "# Initialize parameters\n",
+    "# -----------------------------\n",
+    "m, n = X.shape\n",
+    "w = np.zeros((n, 1))\n",
+    "b = 0\n",
+    "alpha = 0.1\n"
+   ]
+  },
+  {
+   "cell_type": "code",
+   "execution_count": null,
+   "id": "b12c8bdd",
+   "metadata": {},
+   "outputs": [],
+   "source": [
+    "# Sigmoid function\n",
+    "# -----------------------------\n",
+    "def sigmoid(z):\n",
+    "    return 1 / (1 + np.exp(-z))\n"
+   ]
+  },
+  {
+   "cell_type": "code",
+   "execution_count": null,
+   "id": "496b0174",
+   "metadata": {},
+   "outputs": [],
+   "source": [
+    "# Training loop\n",
+    "# -----------------------------\n",
+    "iterations = 500\n",
+    "\n",
+    "for i in range(iterations):\n",
+    "    z = np.dot(X, w) + b\n",
+    "    y_hat = sigmoid(z)\n",
+    "        \n",
+    "    loss = -(1/m) * np.sum(y * np.log(y_hat) + (1 - y) * np.log(1 - y_hat))\n",
+    "    \n",
+    "    dw = (1/m) * np.dot(X.T, (y_hat - y))\n",
+    "    db = (1/m) * np.sum(y_hat - y)\n",
+    "    \n",
+    "    w = w - alpha * dw\n",
+    "    b = b - alpha * db"
+   ]
+  },
+  {
+   "cell_type": "code",
+   "execution_count": null,
+   "id": "3a45614b",
+   "metadata": {},
+   "outputs": [],
+   "source": [
+    "print(\"Final Weights:\\n\", w)\n",
+    "print(\"Final Bias:\\n\", b)\n",
+    "print(\"Final Loss:\", loss)"
+   ]
+  },
+  {
+   "cell_type": "code",
+   "execution_count": null,
+   "id": "e215bb3b",
+   "metadata": {},
+   "outputs": [],
+   "source": []
+  }
